# Copy to .env and adjust if needed. All values below are defaults, so a
# fresh clone works without any .env file.

# Ollama server + models (local, zero-cost)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# DuckDB database file (spatial extension loaded at connect time)
DUCKDB_PATH=data/geocopilot.duckdb

# Chroma persistence dir for phase-3 semantic search over inspection notes
CHROMA_DIR=data/chroma

# FastAPI backend URL the Streamlit frontend calls
API_BASE_URL=http://localhost:8000
